{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.kar.bg/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.kar.bg/media/:path*"
    },
    {
      "source": "/docs/api",
      "destination": "https://api.kar.bg/docs/api/"
    },

    {
      "source": "/details/obiava-:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|linkedinbot|whatsapp|viber|telegrambot|telegram|slackbot|discordbot|redditbot|pinterest|vkshare|skypeuripreview|googlebot|bingbot|duckduckbot|applebot|perplexitybot|gptbot|claudebot).*"
        }
      ],
      "destination": "https://api.kar.bg/prerender/listing/:id/"
    },
    {
      "source": "/details/obiava-:id-:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|linkedinbot|whatsapp|viber|telegrambot|telegram|slackbot|discordbot|redditbot|pinterest|vkshare|skypeuripreview|googlebot|bingbot|duckduckbot|applebot|perplexitybot|gptbot|claudebot).*"
        }
      ],
      "destination": "https://api.kar.bg/prerender/listing/:id/"
    },
    {
      "source": "/dealers/:dealerSlug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|linkedinbot|whatsapp|viber|telegrambot|telegram|slackbot|discordbot|redditbot|pinterest|vkshare|skypeuripreview|googlebot|bingbot|duckduckbot|applebot|perplexitybot|gptbot|claudebot).*"
        }
      ],
      "destination": "https://api.kar.bg/prerender/dealer/:dealerSlug/"
    },

    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
