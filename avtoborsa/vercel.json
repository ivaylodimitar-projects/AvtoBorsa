{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.bwraap.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.bwraap.com/media/:path*"
    },
    {
      "source": "/docs/api",
      "destination": "https://api.bwraap.com/docs/api/"
    },

    {
      "source": "/details/obiava-:id-:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|twitterbot|linkedinbot|whatsapp|slackbot|discordbot|googlebot|bingbot|duckduckbot|applebot|perplexitybot|gptbot|claudebot).*"
        }
      ],
      "destination": "https://api.bwraap.com/prerender/listing/:id/"
    },

    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}